# Local-only agent notes
AGENTS.md

# Default repository publish boundary.
# New files are local unless they are inside one of the public package
# surfaces below or are public repository metadata.
/*

!/.github/
!/.github/**
!/.gitattributes
!/.gitignore
!/Python/
!/R/
!/stata/
!/stata/**
!/README.md
!/LICENSE.md

# Keep only the Python package subtree public under Python/.
/Python/*
!/Python/nprobust_illustration.py
!/Python/nprobust_data.csv
!/Python/nprobust/
!/Python/nprobust/**

# Keep only the R package subtree public under R/.
/R/*
!/R/nprobust_illustration.R
!/R/nprobust_data.csv
!/R/nprobust/
!/R/nprobust/**

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
**/.idea/
**/.vscode/

# Local environments
.env
.env.*
.venv/
venv/
env/
**/.venv/
**/venv/
**/env/

# Python caches and test output
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
fontlist-*.json
.mplconfig/
.pytest_cache/
**/.pytest_cache/
pytest-cache-files-*/
**/pytest-cache-files-*/
.coverage
htmlcov/
**/htmlcov/

# R session and check output
.Rhistory
.RData
.Ruserdata
.Rproj.user/
Rplots.pdf
**/Rplots.pdf
**/.Rhistory
**/.RData
**/.Ruserdata
**/.Rproj.user/
*.Rcheck/
**/*.Rcheck/

# Package build artifacts
build/
dist/
**/build/
**/dist/
*.egg-info/
**/*.egg-info/
*.tar.gz
*.whl

# Logs and temporary files
*.log
*.tmp
*.bak
*.swp
*~
